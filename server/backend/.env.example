FLASK_ENV=development

# ============================================
# LLM CONFIGURATION
# ============================================

GOOGLE_API_KEY=
LLM_MODEL=gemma-3-27b-it
SMALL_LLM_MODEL=gemma-3-4b-it
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# ============================================
# BACKEND CONFIGURATION
# ============================================

BACKEND_API_URL=http://localhost:8386
VOICE_BACKEND_PORT=8387
VOICE_BACKEND_PUBLIC_BASE_URL=http://localhost:8387
EDGE_PAYLOAD_VERSION=2
DEVICE_SESSION_TTL_SECONDS=3600

# ============================================
# WEB SEARCH CONFIGURATION
# ============================================

WEB_SEARCH_SOURCE=duckduckgo_html
WEB_SEARCH_URL=https://html.duckduckgo.com/html/
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT=10
WEB_SEARCH_FETCH_LIMIT=3
FETCH_TIMEOUT=10
FETCH_MAX_CONTENT_CHARS=2500
FETCH_MAX_ITEMS=3

# ============================================
# MEDIA / TTS
# ============================================

YT_DLP_BIN=yt-dlp
YOUTUBE_TOOL_TIMEOUT=25
YOUTUBE_SEARCH_MAX_RESULTS=5
FFMPEG_BIN=ffmpeg
MEDIA_TRANSCODE_TIMEOUT=3600
MEDIA_TRANSCODE_SAMPLE_RATE=16000
MEDIA_TRANSCODE_CHANNELS=1
TTS_VOICE_ID=2
TTS_NORMALIZE_SAMPLE_RATE=16000
TTS_NORMALIZE_CHANNELS=1

# ============================================
# CONVERSATION
# ============================================

MAX_CONVERSATION_HISTORY=5
MAX_MEMORY_ITEMS=20
MAX_CONTEXT_SUMMARY_CHARS=1500

# ============================================
# LOGGING
# ============================================

LOG_LEVEL=INFO
LOG_FILE=llm_pipeline.log
